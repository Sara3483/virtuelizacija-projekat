<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>

	<system.serviceModel>
		<services>
			<service name="VirtuelizacijaProjekat.EisService">
				<endpoint
					address=""
					binding="netTcpBinding"
					bindingConfiguration="TcpBindingConfig"
					contract="Common.IEisService"/>

				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:4000/EisService"/>
					</baseAddresses>
				</host>
			</service>
		</services>

		<bindings>
			<netTcpBinding>
				<binding name="TcpBindingConfig"
						 transferMode="Streamed"
						 maxReceivedMessageSize="10485760"
						 openTimeout="00:01:00"
						 closeTimeout="00:01:00"
						 sendTimeout="00:05:00"
						 receiveTimeout="00:10:00"/>
			</netTcpBinding>
		</bindings>
	</system.serviceModel>

	<appSettings>
		<add key="TransferStartedMessage" value="Transfer started!"/>
		<add key="SampleReceivedMessage" value="Sample received!"/>
		<add key="TransferCompletedMessage" value="Transfer completed!"/>
		<add key="WarningMessage" value="WARNING: Invalid sample!"/>

		<add key="PhaseAngleShiftMessage" value="Phase angle shift detected!"/>
		<add key="PhiThreshold" value="0.01"/>

		<add key="ReactiveRatioOutOfBoundsMessage" value="Reactive ratio out of bounds!"/>
		<add key="ReactiveRatioWarningMessage" value="Reactive ratio warning!"/>
		<add key="QMin" value="0.0"/>
		<add key="QMax" value="10.0"/>
		<add key="QDev" value="0.20"/>
		
		<add key="MaxFrequency" value="100000"/>

		<add key="V_threshold" value="0.2"/>
		<add key="Z_threshold" value="0.2"/>
	</appSettings>
</configuration>

